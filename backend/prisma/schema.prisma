generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  username     String?
  email        String    @unique     
  phone_number String    @unique
  verified     Boolean   @default(false)
  booking      Booking[]
  payment      Payment[]
}

model Admin {
  id           String  @id @default(uuid())
  username     String?
  phone_number String  @unique
  verified     Boolean @default(false)
  events       Event[]
}

model Booking {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  checkedIn Boolean  @default(false)
  checkInAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
  seats     Seat[]
}

model Seat {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  bookingId String
  quantity  Int
  type      SeatType
  booking  Booking @relation(fields: [bookingId], references: [id])
}

enum SeatType {
  Silver
  Gold
  Diamond
}

model Event {
  id          String    @id @default(uuid())
  name        String    @unique
  description String
  type        EventType
  tag         String?
  venue       String
  date        DateTime
  capacity    Int
  price       Float
  startTime   DateTime?
  endTime     DateTime?
  available   Boolean   @default(true)
  amenities   String[]
  adminId     String
  admin       Admin     @relation(fields: [adminId], references: [id])
  bookings    Booking[]
  payments    Payment[]
}

enum EventType {
  Concert
  Workshop
  Gala
  Conference
}

model Payment {
  id      String       @id @default(uuid())
  eventId String
  userId  String
  status  PaymentState
  user    User         @relation(fields: [userId], references: [id])
  event   Event        @relation(fields: [eventId], references: [id])
}

enum PaymentState {
  Success
  Fail
  Pending
}
