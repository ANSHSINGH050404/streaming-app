generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(uuid())
  username     String?
  phone_number String  @unique
  verified     Boolean @default(false)
}


model Admin {
  id           String  @id @default(uuid())
  username     String?
  phone_number String  @unique
  verified     Boolean @default(false)
}